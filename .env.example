# Only needed for the OPTIONAL voice layer (scripts/gen-voice.mjs).
# Get a key at https://elevenlabs.io → profile → API Keys.
# The free tier works for testing; commercial use requires a paid plan.
ELEVENLABS_API_KEY=

# Optional: force a specific voice by name (otherwise the script picks the
# first match from its preference list — deep/warm narration voices).
# ELEVENLABS_VOICE=Callum
